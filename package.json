{
  "name": "strudel-bf",
  "version": "0.1.0",
  "private": true,
  "description": "A Brainfuck layer on top of the Strudel REPL for live-coded beats.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erodola/strudel-bf.git"
  },
  "homepage": "https://github.com/erodola/strudel-bf",
  "bugs": {
    "url": "https://github.com/erodola/strudel-bf/issues"
  },
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24.13.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace @strudel-bf/web",
    "postinstall": "node scripts/patch-kabelsalat-web.mjs",
    "test:e2e": "playwright test",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "24.6.0",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.4",
    "jsdom": "26.1.0",
    "typescript": "5.9.3",
    "vite": "7.3.3",
    "vitest": "3.2.4"
  }
}
